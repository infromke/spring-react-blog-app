{
  "name": "blog-server",
  "version": "1.0.0",
  "description": "Uma API modular para blog desenvolvida com Node.js, Express e PostgreSQL",
  "private": true,
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --watch ./src/server.js",
    "sequelize:migrate": "npx sequelize-cli db:migrate",
    "sequelize:undo": "npx sequelize-cli db:migrate:undo",
    "sequelize:reset": "npx sequelize-cli db:migrate:undo:all"
  },
  "dependencies": {
    "bcrypt": "6.0.0",
    "cookie-parser": "1.4.7",
    "express": "5.2.1",
    "express-rate-limit": "8.2.1",
    "express-validator": "7.3.1",
    "jsonwebtoken": "9.0.3",
    "multer": "2.0.2",
    "pg": "8.16.3",
    "pg-hstore": "2.3.4",
    "sequelize": "6.37.7",
    "sharp": "0.34.5",
    "slugify": "1.6.6",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "sequelize-cli": "6.6.5"
  }
}
